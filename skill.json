{
  "name": "travaso-mcp",
  "version": "1.2.0",
  "description": "AI agent skill for Travaso MCP \u2014 sell hotels from any agent and earn 3-20% commission per booking.",
  "homepage": "https://elitetravelsales.com/tokens",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tarzelf/travaso-mcp-skill"
  },
  "license": "MIT",
  "author": {
    "name": "Tarzelf / Hermes Agent"
  },
  "mcp": {
    "endpoint": "https://elitetravelsales.com/api/backend/mcp",
    "endpoint_alias": {
      "url": "https://elitetravelsales.com/mcp",
      "redirects_to": "https://elitetravelsales.com/api/backend/mcp",
      "redirect_status": 307
    },
    "transport": "http",
    "tools": [
      "search_competitive_hotel_quotes",
      "create_offer_checkout_link",
      "get_offer_status",
      "cancel_offer"
    ]
  },
  "auth": {
    "canonical_env_var": "TRAVASO_AGENT_TOKEN",
    "fallback_env_vars": ["TRAVASO_TOKEN", "TRAVASO_API_KEY"],
    "primary_header_format": "Authorization: Bearer <TRAVASO_AGENT_TOKEN>",
    "fallback_header_format": "x-travaso-agent-token: <TRAVASO_AGENT_TOKEN>"
  },
  "rest_fallbacks": {
    "search": "POST https://elitetravelsales.com/api/backend/agent/hotel-quotes",
    "checkout": "POST https://elitetravelsales.com/api/backend/agent/checkout-link",
    "stats": "GET https://elitetravelsales.com/api/backend/agent/portal/stats"
  },
  "pricing": {
    "free": { "commission_pct": 3 },
    "monthly": { "commission_pct_min": 10, "commission_pct_max": 20 },
    "annual": { "commission_pct_min": 10, "commission_pct_max": 20 }
  },
  "install": {
    "vercel_skills": "npx skills add Tarzelf/travaso-mcp-skill",
    "hermes": "~/.hermes/skills/mcp/travaso-mcp/",
    "mcp_config": {
      "mcpServers": {
        "travaso": {
          "url": "https://elitetravelsales.com/api/backend/mcp",
          "headers": {
            "Authorization": "Bearer <TRAVASO_AGENT_TOKEN>"
          }
        }
      }
    },
    "claude_code_terminal": "claude mcp add --transport http travaso https://elitetravelsales.com/api/backend/mcp --header \"Authorization: Bearer <TRAVASO_AGENT_TOKEN>\""
  },
  "tags": ["mcp", "travel", "hotels", "commerce", "agent-economy", "commission", "stripe"]
}